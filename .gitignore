# =========================
# StockFlow .gitignore
# =========================

# Environment files
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Python virtual environments
venv/
.venv/
env/
ENV/
backend/venv/
backend/.venv/

# FastAPI / backend logs
*.log
logs/

# Alembic note:
# Do NOT ignore alembic migration files.
# They should be committed when generated.

# Node / Angular
node_modules/
frontend/node_modules/
dist/
frontend/dist/
.angular/
frontend/.angular/
coverage/
frontend/coverage/

# Angular build/cache
.cache/
frontend/.cache/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE/editor files
.vscode/
.idea/

# Temporary files
*.tmp
*.temp
*.bak
*.swp

# Local database/files
*.sqlite
*.sqlite3
*.db

# Secrets/keys
*.pem
*.key
*.crt
# Local AI prompt pack - private, not for GitHub
docs/prompts/


# Local-only frontend preview credentials
/frontend/src/environments/environment.local.ts
